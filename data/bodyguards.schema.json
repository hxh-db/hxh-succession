{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "護衛・ハンター一覧 スキーマ",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "prince", "is_hunter", "role"],
    "properties": {
      "name":       { "type": "string", "minLength": 1 },
      "prince":     { "type": "string", "minLength": 1 },
      "is_hunter":  { "type": "boolean" },
      "nen_type":   { "type": ["string", "null"] },
      "ability":    { "type": ["string", "null"] },
      "role":       { "type": "string", "minLength": 1 },
      "note":       { "type": ["string", "null"] }
    }
  }
}
