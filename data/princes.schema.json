{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "王子一覧 スキーマ",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["rank", "name", "queen", "status"],
    "properties": {
      "rank":              { "type": "integer", "minimum": 1, "maximum": 14 },
      "name":              { "type": "string", "minLength": 1 },
      "age":               { "type": ["integer", "null"], "minimum": 0 },
      "queen":             { "type": "string" },
      "room":              { "type": ["string", "null"] },
      "nen_type":          { "type": ["string", "null"] },
      "spirit_beast_name": { "type": ["string", "null"] },
      "status":            { "type": "string", "minLength": 1 },
      "faction_note":      { "type": ["string", "null"] },
      "note":              { "type": ["string", "null"] }
    }
  }
}
